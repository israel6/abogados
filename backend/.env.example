# Backend Configuration

# Server
PORT=3000
NODE_ENV=development

# Database - SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=your_password_here
DB_NAME=bufete_abogados

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Encryption
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Payphone API (Button API)
PAYPHONE_TOKEN=your_payphone_bearer_token_here
PAYPHONE_STORE_ID=your_payphone_store_id_here
PAYPHONE_WEBHOOK_SECRET=your_payphone_webhook_secret_here

# SendGrid / Twilio — en desarrollo sin credenciales reales, usar NOTIFICATION_MOCK=true
NOTIFICATION_MOCK=true
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Google Calendar
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key_here
GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet

# Application
APP_NAME=Portal Bufete Abogados
APP_URL=http://localhost:5173
ADMIN_EMAIL=admin@bufete.com
